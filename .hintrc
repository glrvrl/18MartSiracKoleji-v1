{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/name-role-value": "off",
    "disown-opener": "off",
    "axe/text-alternatives": "off",
    "axe/forms": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "backdrop-filter"
        ]
      }
    ],
    "no-inline-styles": "off",
    "axe/parsing": "off",
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "video[playsinline]"
        ]
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not ios_saf <= 26.3",
    "not safari <= 26.3"
  ]
}